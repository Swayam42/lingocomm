# 1. Telegram Bot Token
#    → Open Telegram, message @BotFather
#    → /newbot → give it a name → copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

LINGODOTDEV_API_KEY=your_lingo_dev_api_key_here

# 3. MongoDB Atlas Connection String
#    → https://cloud.mongodb.com → Free tier (M0)
#    → Create cluster → Connect → Drivers → Copy URI
#    → Replace <password> with your actual password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lingocomm?retryWrites=true&w=majority

# 4. Dashboard server port (optional)
PORT=3001

# 5. Your Telegram username (for /stats admin commands)
ADMIN_USERNAME=your_telegram_username
