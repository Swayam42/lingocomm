# 1. Telegram Bot Token
#    → Open Telegram, message @BotFather
#    → /newbot → give it a name → copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

LINGODOTDEV_API_KEY=your_lingo_dev_api_key_here

# 3. MongoDB Atlas Connection String
#    → https://cloud.mongodb.com → Free tier (M0)
#    → Create cluster → Connect → Drivers → Copy URI
#    → Replace <password> with your actual password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lingocomm?retryWrites=true&w=majority

# 4. Dashboard server port (optional)
PORT=3001

# 5. Your Telegram username (for /stats admin commands)
ADMIN_USERNAME=your_telegram_username

# Required for /analyze command
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# 7. Google Cloud TTS Credentials (for Text-to-Speech)
#    → https://console.cloud.google.com
#    → Enable Text-to-Speech API
#    → Create Service Account → Download JSON key file

# LOCAL DEVELOPMENT: Set the path to your JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-cloud-credentials.json

# RENDER / CLOUD DEPLOYMENT: Paste the base64-encoded JSON instead.
# To generate it (Mac/Linux):
#   base64 -i service-account.json | tr -d '\n'
# To generate it (Windows PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\path\to\service-account.json"))
# Then add GOOGLE_CREDENTIALS_BASE64 as an env var in Render's dashboard.
# GOOGLE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii4uLn0=
